{
  "extends": "@modern-js/tsconfig/base",
  "compilerOptions": {
    "declaration": false,
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["./shared/*"],
      "*": ["./*"]
    },
    "allowJs": false,
    "ignoreDeprecations": "6.0"
  },
  "exclude": ["**/node_modules"]
}
